name: ${SERVICE_NAME}
services:
  @@SERVICE_NAME@@:
    image: "${VLLM_IMAGE}"
    container_name: "${SERVICE_NAME}"
    ipc: host
    runtime: nvidia
    gpus: all
    restart: unless-stopped
    environment:
      HF_TOKEN: "${HF_TOKEN:-}"
      HUGGING_FACE_HUB_TOKEN: "${HF_TOKEN:-}"
    volumes:
      - "${HF_CACHE:-./hf-cache}:/root/.cache/huggingface"
    ports:
      - "${BIND_HOST}:${HOST_PORT}:8000"
    command:
      - "--model"
      - "${MODEL_ID}"
      - "--served-model-name"
      - "${SERVED_MODEL_NAME}"
@@REVISION_ARGS@@
      - "--host"
      - "0.0.0.0"
      - "--port"
      - "8000"
      - "--max-model-len"
      - "${MAX_MODEL_LEN}"
      - "--tensor-parallel-size"
      - "${TENSOR_PARALLEL_SIZE}"
@@EXTRA_ARGS@@
